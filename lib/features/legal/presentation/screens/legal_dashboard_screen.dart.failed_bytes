  Widget _buildTechnicianBar() {

    final technicians = [

      {'name': 'аёҠа№ҲаёІаёҮаёҲаёҙа№Ҡаёҡ', 'status': 'AIR COND', 'color': const Color(0xFF00FF9F), 'image': 'assets/jib_air.jpg'},

      {'name': 'аёҠа№ҲаёІаёҮаё§аёҙаёҠаёұаёў', 'status': 'ELECTRICAL', 'color': const Color(0xFF00FF9F), 'image': 'assets/wichai_electric.jpg'},

      {'name': 'аёҠа№ҲаёІаёҮаёҒа№үаёӯаёҮ', 'status': 'PLUMBING', 'color': const Color(0xFF00FF9F), 'image': 'assets/kong_plumbing.jpg'},

      {'name': 'аёҠа№ҲаёІаёҮа№ҒаёҲа№Үаё„', 'status': 'MASONRY', 'color': const Color(0xFF00FF9F), 'image': 'assets/jack_senior.jpg'},

      {'name': 'аёҠа№ҲаёІаёҮа№ҖаёҒаёЈаёӢ', 'status': 'PAINTING', 'color': const Color(0xFF00FF9F), 'image': 'assets/grace_paint.jpg'},

      {'name': 'аёҠа№ҲаёІаёҮаёһаёө', 'status': 'SYSTEMS', 'color': const Color(0xFF00FF9F), 'image': 'assets/prism_it.jpg'},

      {'name': 'аёҠа№ҲаёІаёҮа№ҖаёӘаёҒ', 'status': 'MAINTENANCE', 'color': const Color(0xFF00FF9F), 'image': 'assets/coupe_maint.jpg'},

    ];



    return SingleChildScrollView(

      scrollDirection: Axis.horizontal,

      child: Row(

        mainAxisAlignment: MainAxisAlignment.center,

        children: technicians.map((tech) {

          return TechnicianCard(

            name: tech['name'] as String,

            status: tech['status'] as String,

            statusColor: tech['color'] as Color,

            imagePath: tech['image'] as String?,

            isActive: _random.nextBool(),

          );

        }).toList(),

      ),

    );

  }



